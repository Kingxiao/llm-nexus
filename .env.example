# LLM Provider API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
302AI_API_KEY=your_302ai_key_here

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# AWS Bedrock (uses AWS credential chain: env vars, IAM role, SSO)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Proxy Server
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8080
NEXUS_CONFIG_DIR=config
NEXUS_PROXY_AUTH_TOKEN=your_proxy_auth_token_here

# Metrics
NEXUS_METRICS_DB=your_metrics_db_path_here

# Registry
NEXUS_REGISTRY_SYNC_INTERVAL_SECS=3600
